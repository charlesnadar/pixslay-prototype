var TRIP_SCENE_LIST = ['bonfire','forest','lake','night','waterfall',
                       'food','selfie','travel','group'];
var TRIP_BY_LIST    = ['VR','MA','KA','?','VR','MA','KA','VR','?','MA'];
var TRIP_PHOTOS = (function() {
