## Photo Tap Behaviour

### Single tap = always open full screen
Single tap on a photo ALWAYS opens full screen view. Never conditionally block this.

```javascript
function photoTap(index) {
  state.currentPhoto = index;
  state.prevScreen   = state.screen;
  go('photo-full');
}
```

### Long press = enter selection mode
Set up long press separately in postRender() after the grid is in the DOM:

```javascript
function setupLongPress() {
  document.querySelectorAll('.photo-cell').forEach((cell, i) => {
    let timer;
    const start = () => { timer = setTimeout(() => enterSelectionMode(i), 600); };
    const cancel = () => clearTimeout(timer);
    cell.addEventListener('touchstart', start, { passive: true });
    cell.addEventListener('touchend',   cancel);
    cell.addEventListener('touchmove',  cancel);
    cell.addEventListener('mousedown',  start);
    cell.addEventListener('mouseup',    cancel);
    cell.addEventListener('mouseleave', cancel);
  });
}

function enterSelectionMode(index) {
  state.selectionMode = true;
  state.selectedPhotos = new Set([index]);
  render();
}
```

### In selection mode — tap toggles selection, does NOT open full screen
Override the onclick in selection mode:

```javascript
function photoTap(index) {
  if (state.selectionMode) {
    if (state.selectedPhotos.has(index)) state.selectedPhotos.delete(index);
    else state.selectedPhotos.add(index);
    updateSelectionUI();
    return;
  }
  // Not in selection mode — always open full screen
  state.currentPhoto = index;
  state.prevScreen   = state.screen;
  go('photo-full');
}
```

