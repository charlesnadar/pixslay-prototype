## State Management

Single global state object. One render() function. Full screen swap on every state change.
Never patch innerHTML on a live screen — always call render() to replace the whole screen.

```javascript
const state = {
  screen:     'entry',
  journey:    null,
  completed:  [],
  identifiedFaces: [],      // [{index: 0-4, name: 'Beulah'}]
  selectionMode:   false,
  selectedPhotos:  new Set(),
  sharedPhotos:    new Set(),
  savedPhotos:     new Set(),
  activeFilters: {
    mainTab: 'my',          // 'my' | 'with'
    cat:     null,          // 'People' | 'Scene' | 'Format' | 'Time'
    sub:     null,          // active sub-filter string
    tab:     'all',         // 'all' | 'shared' | 'received' | 'saved' | 'downloaded'
  },
  currentPhoto: 0,
  prevScreen:   null,
};

function go(screenName) {
  state.screen = screenName;
  render();
}

function markComplete(journey) {
  if (!state.completed.includes(journey)) state.completed.push(journey);
  // Reset journey-specific state
  state.identifiedFaces  = [];
  state.selectedPhotos   = new Set();
  state.sharedPhotos     = new Set();
  state.savedPhotos      = new Set();
  state.selectionMode    = false;
  state.activeFilters    = { mainTab:'my', cat:null, sub:null, tab:'all' };
  go('entry');
}
```

