## Filter Bar — Clickable Category and Sub-chips

```javascript
function filterBar(activeCat, activeSub) {
  const categories = ['People', 'Scene', 'Format', 'Time'];
  const subOptions = {
    People: ['Varun','Beulah','Kavitha','Mayank','Vishal','Anand'],
    Scene:  ['Bonfire','Waterfall','Group shot','Night sky','Forest','Food','Lakeside'],
    Format: ['Selfie','Group','Portrait','Landscape','Video'],
    Time:   ['Day 1 (Sat)','Day 2 (Sun)','Morning','Evening','Night'],
  };
  const subs = activeCat ? subOptions[activeCat] : [];

  return `
    <div style="background:#fff;border-bottom:0.5px solid ${T.bgSub};flex-shrink:0;">
      <!-- Category chips -->
      <div style="display:flex;gap:8px;padding:8px 16px;overflow-x:auto;">
        ${categories.map(cat => `
          <button
            onclick="filterCatClick('${cat}')"
            style="height:32px;border-radius:16px;padding:0 14px;border:none;
                   font-family:inherit;font-size:12px;font-weight:500;cursor:pointer;
                   white-space:nowrap;flex-shrink:0;
                   background:${activeCat===cat ? T.blue : T.bgSub};
                   color:${activeCat===cat ? '#fff' : T.textS};"
          >${cat}</button>`).join('')}
      </div>
      <!-- Sub-chips (only when a category is active) -->
      ${subs.length > 0 ? `
        <div style="display:flex;gap:8px;padding:0 16px 8px;overflow-x:auto;">
          ${subs.map(sub => `
            <button
              onclick="filterSubClick('${sub}')"
              style="height:30px;border-radius:15px;padding:0 12px;border:none;
                     font-family:inherit;font-size:11px;font-weight:500;cursor:pointer;
                     white-space:nowrap;flex-shrink:0;
                     background:${activeSub===sub ? T.blue : T.bgSub};
                     color:${activeSub===sub ? '#fff' : T.textS};"
            >${sub}</button>`).join('')}
        </div>` : ''}
    </div>`;
}

function filterCatClick(cat) {
  // Toggle: tap active category = collapse sub-row
  state.activeFilters.cat = state.activeFilters.cat === cat ? null : cat;
  state.activeFilters.sub = null;
  render();
}

function filterSubClick(sub) {
  state.activeFilters.sub = state.activeFilters.sub === sub ? null : sub;
  render();
  // After render, dim non-matching photos
  applyPhotoFilter();
}

function applyPhotoFilter() {
  if (!state.activeFilters.sub) {
    document.querySelectorAll('.photo-cell').forEach(c => c.style.opacity = '1');
    return;
  }
  // Deterministic filter: keep every 3rd and 5th photo to show the effect
  document.querySelectorAll('.photo-cell').forEach((c, i) => {
    c.style.opacity = (i%3===0 || i%5===0) ? '1' : '0.2';
    c.style.transition = 'opacity .3s';
  });
}
```

